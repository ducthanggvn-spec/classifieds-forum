# Tệp .gitignore gốc của toàn dự án

# Dependencies
node_modules/

# Files Môi trường (Cực kỳ quan trọng để bảo mật)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js
web/.next/
web/out/

# Prisma
backend/prisma/*.db
backend/prisma/*.db-journal

# File hệ thống
.DS_Store
Thumbs.db

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
